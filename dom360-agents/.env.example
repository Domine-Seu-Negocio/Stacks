# DOM360-Agents stack — env vars (mirror of the live Portainer stack `sdr`).
# In Portainer (git-backed stack) these are set in the stack's Environment tab,
# NOT committed. For manual CLI deploy: cp .env.example .env && fill in, then
#   set -a && . ./.env && set +a && docker stack deploy -c docker-stack.yml sdr
# Every value below maps to a ${VAR} the stack consumes.

# --- PostgreSQL (shared with the SDK stack) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=dom360_db_sdk
DB_USER=postgres
DB_PASSWORD=

# --- SDK backend bridge ---
SDK_BACKEND_URL=https://api-dev.domineseunegocio.com.br
SDK_API_TOKEN=
# Must be an sdk_* token, NOT a user JWT.
SDK_VOICE_API_TOKEN=
SDK_VOICE_ENABLED=true
SDK_VOICE_TENANT_ID=0
SDK_VOICE_INBOX_ID=0
# Shared secret for SDK <-> Agents mutual auth (must match the SDK stack).
AGENT_SHARED_SECRET=

# --- LLM / cloud providers ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
GROQ_API_KEY=
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_KB_ID=HNFLQEINAK
KB_PROVIDER=vectorizer

# --- LiveKit (self-hosted) ---
# Must match the keys baked into dom360_livekit_config / dom360_livekit_sip_config.
LIVEKIT_URL=ws://livekit-server:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Set after running telephony setup_all_trunks().
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# --- SIP ---
# native (LiveKit SIP trunks) or legacy (pyVoIP bridge)
SIP_MODE=native

# WaVoIP trunk
WAVOIP_SIP_SERVER=sipv2.wavoip.com
WAVOIP_SIP_PORT=5060
WAVOIP_DEVICE_TOKEN=
WAVOIP_SIP_USERNAME=
WAVOIP_SIP_PASSWORD=

# Krolik trunk
KROLIK_SIP_SERVER=54.232.108.90
KROLIK_SIP_PORT=5060
KROLIK_SIP_USERNAME=
KROLIK_SIP_PASSWORD=

# --- Runtime ---
LOG_LEVEL=INFO
VOICE_IDLE_PROCESSES=1
