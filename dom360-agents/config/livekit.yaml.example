# LiveKit Server config — production template.
# Bootstrap as an immutable external Swarm config (configs can't be edited —
# create a new versioned name and point the stack at it):
#   cp config/livekit.yaml.example config/livekit.yaml   # fill real keys + IP
#   docker config create dom360_livekit_config_<date> config/livekit.yaml
#   # then set configs.livekit_config.name in docker-stack.yml and redeploy
#
# Generate keys: docker run --rm livekit/livekit-server generate-keys

port: 7880

rtc:
  port_range_start: 50000      # MUST match the published 50000-50100/udp host ports
  port_range_end: 50100
  tcp_port: 7881               # ICE/TCP fallback for restrictive NAT (published, mode:host)
  # Single-node Swarm with a static public IP: pin the advertised media IP via
  # 1:1 NAT and disable STUN rewriting. This avoids overlapping ICE candidates
  # (the "overlapping address rewrite rule" warning) that cause intermittent
  # media — calls connecting sometimes and dropping mid-session. Local interface
  # candidates are still gathered, so the in-overlay worker uses the local path.
  # node_ip pins the advertised media IP for this LiveKit build (1.12.0).
  # NOTE: the field is `node_ip` (singular), NOT `nat_1_to_1_ips` — the latter
  # is rejected by this build ("field nat_1_to_1_ips not found in RTCConfig").
  use_external_ip: false
  node_ip: REPLACE_NODE_PUBLIC_IP

redis:
  address: livekit-redis:6379

keys:
  REPLACE_API_KEY: REPLACE_API_SECRET

logging:
  level: info
  pion_level: warn

turn:
  enabled: false
