# SDK stack — env vars (mirror of the live Portainer stack `sdk`).
# In Portainer (git-backed stack) these are set in the stack's Environment tab,
# NOT committed. For manual CLI deploy: cp .env.example .env && fill in, then
#   set -a && . ./.env && set +a && docker stack deploy -c docker-stack.yml sdk
# Every value below maps to a ${VAR} the stack consumes.

# --- Images (registry tags/digests — bump here to release) ---
API_V2_IMAGE=johannalves/sdk:api-v2-rust-dev
FRONTEND_IMAGE=johannalves/sdk:frontend-rust-dev

# --- api-v2 bind ---
SDK_V2_BIND_ADDR=0.0.0.0:3001
RUST_LOG=info,dom360_sdk_v2=info

# --- PostgreSQL (shared with the agents stack) ---
DB_HOST=db
DB_PORT=5432
DB_NAME=dom360_db_sdk
DB_USER=postgres
DB_PASSWORD=

# --- Public hosts / Traefik (dev) ---
PUBLIC_FRONTEND_HOST=sdk-dev.domineseunegocio.com.br
PUBLIC_BACKEND_HOST=api-dev.domineseunegocio.com.br
PUBLIC_BACKEND_URL=https://api-dev.domineseunegocio.com.br
PUBLIC_WHITELABEL_HOST=wl-front.domineseunegocio.com.br
CORS_ORIGINS=https://sdk-dev.domineseunegocio.com.br,https://api-dev.domineseunegocio.com.br
MCP_PROXY_SDK_BACKEND_URL=https://api-dev.domineseunegocio.com.br

# --- Security ---
JWT_SECRET=
# 32-byte base64 (openssl rand -base64 32) — encrypts Google OAuth tokens.
GOOGLE_TOKEN_ENCRYPTION_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LLM / providers ---
LLM_PROVIDER=openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
ELEVENLABS_API_KEY=

# --- PromptForge ---
PROMPTFORGE_MODEL=
PROMPTFORGE_TIMEOUT=
PROMPTFORGE_MAX_TOKENS=
PROMPTFORGE_MAX_INPUT_CHARS=
PROMPTFORGE_DEBUG=

# --- Vectorizer Knowledge Base ---
VECTORIZER_KB_ENABLED=true
VECTORIZER_KB_URL=http://vectorizer:15002
VECTORIZER_API_KEY=
VECTORIZER_KB_MAX_FILE_SIZE_MB=50
VECTORIZER_MODE=debug

# --- DOM360-Agents bridge ---
AGENT_API_URL=http://sdr-agent:8000
# Shared secret for SDK <-> Agents mutual auth (must match the agents stack).
AGENT_SHARED_SECRET=

# --- Frontend (Vite) ---
NODE_ENV=production
FRONTEND_BIND_PORT=5173
VITE_API_URL=
VITE_API_V2_URL=
VITE_BACKEND_URL=
