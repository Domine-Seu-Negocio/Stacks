# SDK stack — copy to .env (git-ignored) and fill in.
#   cp .env.example .env && nano .env
#   set -a && . ./.env && set +a   # export before `docker stack deploy`
# Every value below maps to a ${VAR} in docker-stack.yml.

# --- Images (registry tags/digests — bump here to release) ---
API_V2_IMAGE=johannalves/sdk:api-v2-rust-dev
FRONTEND_IMAGE=johannalves/sdk:frontend-rust-dev

# --- api-v2 bind ---
SDK_V2_BIND_ADDR=0.0.0.0:3001

# --- PostgreSQL (shared with DOM360-Agents) ---
DB_HOST=db
DB_PORT=5432
DB_NAME=dom360_db_sdk
DB_USER=postgres
DB_PASSWORD=

# --- Public URLs / Traefik hosts ---
PUBLIC_FRONTEND_HOST=sdk.srcjohann.com.br
PUBLIC_BACKEND_HOST=api.srcjohann.com.br
PUBLIC_BACKEND_URL=https://api.srcjohann.com.br
PUBLIC_WHITELABEL_ROOT_DOMAIN=srcjohann.com.br
CORS_ORIGINS=https://sdk.srcjohann.com.br,https://api.srcjohann.com.br

# --- Security ---
JWT_SECRET=
# 32-byte base64 (openssl rand -base64 32) — encrypts Google OAuth tokens.
GOOGLE_TOKEN_ENCRYPTION_KEY=

# --- LLM / providers ---
LLM_PROVIDER=openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
ELEVENLABS_API_KEY=

# --- Vectorizer Knowledge Base ---
VECTORIZER_KB_ENABLED=true
VECTORIZER_KB_URL=http://vectorizer:15002
VECTORIZER_API_KEY=
MCP_PROXY_SDK_BACKEND_URL=https://api.srcjohann.com.br

# --- DOM360-Agents bridge ---
AGENT_API_URL=http://sdr-agent:8000
AGENTS_BASE_URL=http://sdr-agent:8000
# Shared secret for SDK <-> Agents mutual auth (must match the agents stack).
AGENT_SHARED_SECRET=

# --- Misc ---
BRANDING_ASSETS_DIR=/home/sdk/branding-assets
RUST_LOG=info,dom360_sdk_v2=info

# --- Frontend (Vite, baked at build time / runtime) ---
NODE_ENV=production
FRONTEND_BIND_PORT=5173
VITE_API_URL=
VITE_API_V2_URL=
VITE_BACKEND_URL=
