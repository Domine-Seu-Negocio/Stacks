# Prometheus stack — copy to .env (git-ignored) and fill in.

# Grafana admin (required — grafana refuses to start without it)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change-me-strong

# Basic-auth for the Prometheus + Alertmanager UIs (Traefik middleware).
# Generate: htpasswd -nbB admin '<password>'  (escape $ as $$ for compose)
PROM_BASICAUTH=admin:$$2y$$05$$REPLACE_WITH_BCRYPT_HASH

# Slack webhook is NOT set here — it is a Swarm secret:
#   printf '%s' 'https://hooks.slack.com/services/XXX' | docker secret create alertmanager_slack_url -
